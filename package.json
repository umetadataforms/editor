{
  "name": "umetadataformseditor",
  "productName": "uMetadataFormsEditor",
  "appId": "github.com.umetadataforms.editor",
  "version": "0.0.2",
  "description": "Prototype desktop editor for completing health data metadata documents.",
  "homepage": "./",
  "license": "MIT",
  "author": {
    "name": "Artur Akbarov",
    "email": "a.akbarov@imperial.ac.uk"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/umetadataforms/editor.git"
  },
  "type": "module",
  "main": "electron-dist/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "build:electron:watch": "tsc -p tsconfig.electron.json -w",
    "dev:electron": "concurrently -k \"npm:dev\" \"npm:build:electron:watch\" \"wait-on http://localhost:5173 && ELECTRON_START_URL=http://localhost:5173 electron .\"",
    "lint": "eslint .",
    "preview": "vite preview",
    "start:electron": "ELECTRON_BUILD=true npm run build && npm run build:electron && electron .",
    "package:electron": "ELECTRON_BUILD=true npm run build && npm run build:electron && electron-builder"
  },
  "dependencies": {
    "@mantine/core": "^8.3.15",
    "@mantine/dates": "^8.3.15",
    "@mantine/hooks": "^8.3.15",
    "@mantine/notifications": "^8.3.15",
    "@rjsf/core": "^6.3.1",
    "@rjsf/mantine": "^6.3.1",
    "@rjsf/mui": "^6.3.1",
    "@rjsf/utils": "^6.3.1",
    "@rjsf/validator-ajv8": "^6.3.1",
    "@tabler/icons-react": "^3.37.1",
    "@tiptap/core": "^3.20.0",
    "@tiptap/extension-link": "^3.20.0",
    "@tiptap/extension-underline": "^3.20.0",
    "@tiptap/react": "^3.20.0",
    "@tiptap/starter-kit": "^3.20.0",
    "cors": "^2.8.5",
    "dayjs": "^1.11.19",
    "dompurify": "^3.3.1",
    "express": "^4.21.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-resizable": "^3.1.3",
    "react-rnd": "^10.5.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/dompurify": "^3.0.5",
    "@types/lodash": "^4.17.23",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/react-resizable": "^3.0.8",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "electron": "^33.2.0",
    "electron-builder": "^24.13.3",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "wait-on": "^8.0.2"
  },
  "build": {
    "files": [
      "dist/**",
      "electron-dist/**",
      "electron/preload.cjs",
      "assets/icons/**",
      "python/**",
      "package.json"
    ],
    "asarUnpack": [
      "python/**"
    ],
    "directories": {
      "output": "release"
    },
    "linux": {
      "target": [
        "deb",
        "AppImage"
      ],
      "category": "Utility",
      "icon": "assets/icons" 
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "assets/icons/uMFE.ico"
    },
    "nsis": {
      "oneClick": false,
      "license": "assets/license-nsis-installer.txt"
    }
  }
}
